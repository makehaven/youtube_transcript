<?php

use Drupal\taxonomy\Entity\Term;

/**
 * Number of consecutive fetch failures before a video is skipped by cron.
 */
const YOUTUBE_TRANSCRIPT_MAX_FAILURES = 3;

/**
 * Implements hook_cron().
 *
 * Fetches missing transcripts for both badge taxonomy terms and tool_video
 * paragraphs. Processes up to 5 of each per cron run. Videos that have
 * failed YOUTUBE_TRANSCRIPT_MAX_FAILURES times are skipped permanently
 * (unless reset via Drush --overwrite or the admin UI).
 */
function youtube_transcript_cron() {
  _youtube_transcript_cron_badges();
  _youtube_transcript_cron_tool_videos();
}

/**
 * Cron sub-task: fetch missing transcripts for badge taxonomy terms.
 */
function _youtube_transcript_cron_badges() {
  $storage = \Drupal::entityTypeManager()->getStorage('taxonomy_term');
  $logger  = \Drupal::logger('youtube_transcript');
  $kv      = \Drupal::keyValue('youtube_transcript');

  $last_id = \Drupal::state()->get('youtube_transcript.cron_last_badge_tid', 0);

  $or = $storage->getQuery()->orConditionGroup()
    ->notExists('field_badge_video_transcript')
    ->condition('field_badge_video_transcript', '', '=');

  $tids = $storage->getQuery()
    ->condition('vid', 'badges')
    ->condition('field_badge_video', '', '<>')
    ->condition($or)
    ->condition('tid', $last_id, '>')
    ->sort('tid', 'ASC')
    ->range(0, 5)
    ->accessCheck(FALSE)
    ->execute();

  if (empty($tids)) {
    \Drupal::state()->set('youtube_transcript.cron_last_badge_tid', 0);
    return;
  }

  /** @var \Drupal\youtube_transcript\YoutubeTranscriptFetcher $fetcher */
  $fetcher = \Drupal::service('youtube_transcript.fetcher');

  foreach ($storage->loadMultiple($tids) as $term) {
    $tid = $term->id();

    // Skip if transcript was filled since the query ran.
    if (!$term->get('field_badge_video_transcript')->isEmpty()) {
      \Drupal::state()->set('youtube_transcript.cron_last_badge_tid', $tid);
      continue;
    }

    $url = $term->get('field_badge_video')->getValue()[0]['input'] ?? '';
    $video_id = $fetcher->extractVideoId($url);

    if (!$video_id) {
      \Drupal::state()->set('youtube_transcript.cron_last_badge_tid', $tid);
      continue;
    }

    // Skip permanently-failing videos.
    $fail_key = 'fail_' . $video_id;
    if (($kv->get($fail_key, 0)) >= YOUTUBE_TRANSCRIPT_MAX_FAILURES) {
      $logger->warning('youtube_transcript: skipping badge term @tid — video @vid has failed @n times. Fix captions in YouTube Studio or run Drush with --overwrite to reset.', [
        '@tid' => $tid, '@vid' => $video_id, '@n' => YOUTUBE_TRANSCRIPT_MAX_FAILURES,
      ]);
      \Drupal::state()->set('youtube_transcript.cron_last_badge_tid', $tid);
      continue;
    }

    $result = $fetcher->fetchAndStoreTranscript($term);

    if ($result) {
      $kv->delete($fail_key);
      $logger->notice('youtube_transcript: saved transcript for badge term @tid (@label).', [
        '@tid' => $tid, '@label' => $term->label(),
      ]);
    }
    else {
      $fails = $kv->get($fail_key, 0) + 1;
      $kv->set($fail_key, $fails);
      $logger->warning('youtube_transcript: failed for badge term @tid (attempt @n/@max): @err', [
        '@tid' => $tid, '@n' => $fails, '@max' => YOUTUBE_TRANSCRIPT_MAX_FAILURES,
        '@err' => $fetcher->getLastError(),
      ]);
    }

    \Drupal::state()->set('youtube_transcript.cron_last_badge_tid', $tid);
  }
}

/**
 * Cron sub-task: fetch missing transcripts for tool_video paragraphs.
 */
function _youtube_transcript_cron_tool_videos() {
  $storage = \Drupal::entityTypeManager()->getStorage('paragraph');
  $logger  = \Drupal::logger('youtube_transcript');
  $kv      = \Drupal::keyValue('youtube_transcript');

  $last_id = \Drupal::state()->get('youtube_transcript.cron_last_pid', 0);

  $or = $storage->getQuery()->orConditionGroup()
    ->notExists('field_video_transcript')
    ->condition('field_video_transcript', '', '=');

  $ids = $storage->getQuery()
    ->condition('type', 'tool_video')
    ->condition('field_video_url', '', '<>')
    ->condition($or)
    ->condition('id', $last_id, '>')
    ->sort('id', 'ASC')
    ->range(0, 5)
    ->accessCheck(FALSE)
    ->execute();

  if (empty($ids)) {
    \Drupal::state()->set('youtube_transcript.cron_last_pid', 0);
    return;
  }

  /** @var \Drupal\youtube_transcript\YoutubeTranscriptFetcher $fetcher */
  $fetcher = \Drupal::service('youtube_transcript.fetcher');

  foreach ($storage->loadMultiple($ids) as $paragraph) {
    $pid = $paragraph->id();

    if (!$paragraph->get('field_video_transcript')->isEmpty()) {
      \Drupal::state()->set('youtube_transcript.cron_last_pid', $pid);
      continue;
    }

    $url      = $paragraph->get('field_video_url')->first()->input ?? '';
    $video_id = $fetcher->extractVideoId($url);

    if (!$video_id) {
      \Drupal::state()->set('youtube_transcript.cron_last_pid', $pid);
      continue;
    }

    $fail_key = 'fail_' . $video_id;
    if (($kv->get($fail_key, 0)) >= YOUTUBE_TRANSCRIPT_MAX_FAILURES) {
      $logger->warning('youtube_transcript: skipping paragraph @pid — video @vid has failed @n times. Fix captions in YouTube Studio or run Drush with --overwrite to reset.', [
        '@pid' => $pid, '@vid' => $video_id, '@n' => YOUTUBE_TRANSCRIPT_MAX_FAILURES,
      ]);
      \Drupal::state()->set('youtube_transcript.cron_last_pid', $pid);
      continue;
    }

    $transcript = $fetcher->fetchTranscript($video_id);

    if ($transcript) {
      $kv->delete($fail_key);
      $paragraph->set('field_video_transcript', $transcript);
      $paragraph->save();
      $logger->notice('youtube_transcript: saved transcript for paragraph @pid (video @vid).', [
        '@pid' => $pid, '@vid' => $video_id,
      ]);
    }
    else {
      $fails = $kv->get($fail_key, 0) + 1;
      $kv->set($fail_key, $fails);
      $logger->warning('youtube_transcript: failed for paragraph @pid (attempt @n/@max): @err', [
        '@pid' => $pid, '@n' => $fails, '@max' => YOUTUBE_TRANSCRIPT_MAX_FAILURES,
        '@err' => $fetcher->getLastError(),
      ]);
    }

    \Drupal::state()->set('youtube_transcript.cron_last_pid', $pid);
  }
}

/**
 * Implements hook_entity_presave().
 *
 * When a badge term's video URL changes, clear the existing transcript so
 * cron picks it up for re-fetch. No synchronous API calls here.
 */
function youtube_transcript_entity_presave(\Drupal\Core\Entity\EntityInterface $entity) {
  if (!($entity instanceof Term) || $entity->bundle() !== 'badges') {
    return;
  }

  $new_url = $entity->get('field_badge_video')->getValue()[0]['input'] ?? '';
  $original = $entity->original ?? NULL;
  $old_url  = $original ? ($original->get('field_badge_video')->getValue()[0]['input'] ?? '') : '';

  // URL added or changed — clear transcript so cron re-fetches it.
  if ($new_url !== $old_url && $new_url !== '') {
    $entity->set('field_badge_video_transcript', '');

    // Also reset the failure counter for this video so cron will retry.
    if ($video_id = \Drupal::service('youtube_transcript.fetcher')->extractVideoId($new_url)) {
      \Drupal::keyValue('youtube_transcript')->delete('fail_' . $video_id);
    }
  }
}
